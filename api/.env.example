UPLOADS_DIR=./uploads
OUTPUT_DIR=./output
JOBS_DIR=./jobs
JOBS_DB_PATH=./jobs.db
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
MAX_IMAGE_COUNT=10
MAX_IMAGE_SIZE_BYTES=20971520
MAX_AUDIO_SIZE_BYTES=104857600
# inline = run jobs in-process (dev/CI); arq = Redis worker (production)
JOB_QUEUE_BACKEND=inline
REDIS_URL=redis://localhost:6379/0
# Per-IP rate limits (slowapi). Set RATE_LIMIT_ENABLED=false to disable.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GENERATE=6/hour
RATE_LIMIT_JOB_DOWNLOAD=30/hour
RATE_LIMIT_JOB_STATUS=120/minute
# TTL cleanup for job workspaces and stale upload/output files
CLEANUP_TTL_HOURS=168
CLEANUP_INTERVAL_SECONDS=3600
# local or s3 (MinIO, AWS S3, Cloudflare R2)
STORAGE_BACKEND=local
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
# Set to true for Playwright E2E (skips FFmpeg encode, ~1s stub render)
E2E_FAST_RENDER=false
